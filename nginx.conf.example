server {
    server_name 3dfv.atarionsolutions.com;

    # 1. Expo Frontend
    location / {
        root /var/www/3dfv/frontend/dist;
        try_files $uri $uri/ /index.html;
        # Prevent Safari from caching the old React App
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
    }

    # 2. AR Viewer
    location /ar {
        alias /var/www/3dfv/frontend/dist/ar;
        try_files $uri $uri/ /index.html;
    }

    # 3. FastAPI Backend
    location /api/ {
        # The trailing slash automatically strips '/api/' before sending to FastAPI
        proxy_pass http://127.0.0.1:8003/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 4. Static Assets from Backend (like uploaded GLB models)
    location /static/ {
        alias /var/www/3dfv/backend/static/;
        # Enable CORS for static assets to be loaded by AR viewer
        add_header Access-Control-Allow-Origin *;
    }

    # 5. 3D Models
    location /models/ {
        alias /var/www/3dfv/backend/app/3dmodels/;
        add_header Access-Control-Allow-Origin *;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/3dfv.atarionsolutions.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/3dfv.atarionsolutions.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = 3dfv.atarionsolutions.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    server_name 3dfv.atarionsolutions.com;
    listen 80;
    return 404; # managed by Certbot
}
