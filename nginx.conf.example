server {
    server_name 3dfv.atarionsolutions.com;

    # 1. Expo Frontend
    location / {
        root /var/www/3dfv/frontend/dist;
        try_files $uri $uri/ /index.html;
    }

    # 2. AR Viewer
    location /ar {
        alias /var/www/3dfv/frontend/dist/ar;
        try_files $uri $uri/ /index.html;
    }

    # 3. FastAPI Backend
    location /api/ {
        # Strip '/api' before sending to FastAPI
        rewrite ^/api/(.*) /$1 break;
        proxy_pass http://127.0.0.1:8003;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 4. Static Assets from Backend (like uploaded GLB models)
    location /static/ {
        alias /var/www/3dfv/backend/static/;
        # Enable CORS for static assets to be loaded by AR viewer
        add_header Access-Control-Allow-Origin *;
    }
}
